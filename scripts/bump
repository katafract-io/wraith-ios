#!/usr/bin/env bash
# Retired release helper.
#
# TestFlight releases now run through .github/workflows/ship.yml, which:
# - computes the next build number from App Store Connect,
# - rebuilds WireGuardKitGo from source,
# - archives and exports the IPA,
# - uploads via fastlane pilot,
# - distributes to Internal Testing.
#
# Do not use this script to bump, tag, or push builds.

set -euo pipefail

cat <<'EOF'
scripts/bump is retired.

Use the GitHub Actions Ship to TestFlight workflow instead:
  .github/workflows/ship.yml

Normal release path:
  1. Commit app changes on a feature branch.
  2. Merge/push to main or release/*.
  3. Let ship.yml compute the next App Store Connect build number and upload to TestFlight.

This script intentionally exits without changing files, tagging, or pushing.
EOF

exit 1
