# Katafract screenshot pipeline — fastlane snapshot config

project("./WraithVPN.xcodeproj")

devices([
  "iPhone 17 Pro Max",
  "iPad Pro 13-inch (M5)",
])

languages(["en-US"])

# UI test scheme name
scheme("WraithVPNUITests")

output_directory("./fastlane/screenshots")
clear_previous_screenshots(true)
override_status_bar(true)
override_status_bar_arguments("--time 9:41 --batteryState charged --batteryLevel 100")

launch_arguments([
  "--screenshots --skip-onboarding",
])

# Pin to match runner's installed runtime — without this fastlane picks
# 26.4 when both 26.4 and 26.4.1 are installed and the simulators don't match.
ios_version("26.4.1")

skip_open_summary(true)
concurrent_simulators(true)
